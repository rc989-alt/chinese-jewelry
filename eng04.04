<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YÀOCǍO · Ancient Herb Intention Bracelets</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=EB+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --jiliang:   #F2EBD8;
    --jiliang-2: #EAE0C8;
    --jiliang-3: #DDD3B8;
    --wengyan:   #4A7165;
    --wengyan-l: #5E8A7C;
    --jiaoyi:    #7B7845;
    --yingse:    #B8963A;
    --yingse-l:  #CBA94E;
    --chizhang:  #C49080;
    --ink:       #1E1A14;
    --ink-mid:   #4A4438;
    --ink-dim:   #8A8070;
    --white:     #FDFAF4;
  }

  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }

  body {
    background: var(--jiliang);
    color: var(--ink);
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
    cursor: none;
  }

  .cursor { position:fixed; width:7px; height:7px; background:var(--wengyan); border-radius:50%; pointer-events:none; z-index:9999; transform:translate(-50%,-50%); transition:transform 0.1s; }
  .cursor-ring { position:fixed; width:32px; height:32px; border:1px solid rgba(74,113,101,0.45); border-radius:50%; pointer-events:none; z-index:9998; transform:translate(-50%,-50%); transition:transform 0.3s, width 0.3s, height 0.3s, border-color 0.3s; }
  .cursor-ring.hover { width:48px; height:48px; border-color:var(--wengyan); }

  /* NAV */
  nav {
    position:fixed; top:0; left:0; right:0; z-index:100;
    padding:1.8rem 3.5rem;
    display:flex; align-items:center; justify-content:space-between;
    background:rgba(242,235,216,0.9);
    backdrop-filter:blur(12px);
    border-bottom:1px solid var(--jiliang-3);
  }
  .nav-logo {
    font-family:'Cormorant Garamond', serif;
    font-size:1.1rem; font-weight:400; letter-spacing:0.25em;
    color:var(--wengyan); text-decoration:none;
    display:flex; align-items:center; gap:0.8rem;
  }
  .nav-logo-sub {
    font-size:0.72rem; letter-spacing:0.18em; font-style:italic;
    color:var(--ink-dim); font-weight:300;
  }
  .nav-links { display:flex; gap:2.5rem; list-style:none; }
  .nav-links a {
    font-size:0.68rem; letter-spacing:0.18em; text-transform:uppercase;
    color:var(--ink-mid); text-decoration:none; transition:color 0.3s; font-weight:300;
  }
  .nav-links a:hover { color:var(--wengyan); }
  .nav-cta {
    font-size:0.68rem; letter-spacing:0.18em; text-transform:uppercase;
    color:var(--white); background:var(--wengyan);
    padding:0.65rem 1.6rem; text-decoration:none; transition:background 0.3s;
  }
  .nav-cta:hover { background:var(--wengyan-l); }
  .nav-find-link { color: var(--wengyan) !important; }

  /* HERO */
  .hero {
    min-height:100vh;
    display:grid; grid-template-columns:1fr 1fr;
    padding-top:80px; position:relative; overflow:hidden;
  }
  .hero-left {
    display:flex; flex-direction:column; justify-content:center;
    padding:5rem 4rem 5rem 5rem; position:relative; z-index:2;
  }
  .hero-eyebrow {
    font-family:'Jost', sans-serif;
    font-size:0.62rem; letter-spacing:0.45em; text-transform:uppercase;
    color:var(--wengyan); margin-bottom:2rem;
    display:flex; align-items:center; gap:1rem;
  }
  .hero-eyebrow::before { content:''; display:block; width:32px; height:1px; background:var(--wengyan); }
  .hero-title {
    font-family:'Cormorant Garamond', serif;
    font-size:clamp(3rem, 6vw, 5.8rem);
    font-weight:300; line-height:1.05;
    color:var(--ink); letter-spacing:0.02em;
    margin-bottom:0.6rem;
    opacity:0; animation:fadeUp 1s ease 0.3s forwards;
  }
  .hero-title em { font-style:italic; color:var(--wengyan); }
  .hero-subtitle {
    font-family:'EB Garamond', serif;
    font-size:clamp(1.1rem, 2.2vw, 1.6rem);
    font-weight:300; font-style:italic;
    color:var(--yingse); letter-spacing:0.06em;
    margin-bottom:2.5rem;
    opacity:0; animation:fadeUp 1s ease 0.5s forwards;
  }
  .hero-desc {
    font-family:'EB Garamond', serif;
    font-size:1rem; line-height:1.95; color:var(--ink-mid);
    max-width:400px; margin-bottom:3rem; font-weight:400;
    opacity:0; animation:fadeUp 1s ease 0.7s forwards;
  }
  .hero-actions {
    display:flex; gap:1.2rem; align-items:center;
    opacity:0; animation:fadeUp 1s ease 0.9s forwards;
  }
  .entry-strip {
    margin-top: 2.2rem;
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.85rem 1.1rem;
    background: rgba(253,250,244,0.72);
    border: 1px solid var(--jiliang-3);
    max-width: fit-content;
    opacity:0; animation:fadeUp 1s ease 1s forwards;
  }
  .entry-strip-label {
    font-size: 0.56rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-dim);
  }
  .entry-strip a {
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--wengyan);
    text-decoration: none;
    border-bottom: 1px solid rgba(74,113,101,0.35);
    padding-bottom: 2px;
  }
  .btn-main {
    font-family:'Jost',sans-serif; font-size:0.68rem;
    letter-spacing:0.2em; text-transform:uppercase;
    color:var(--white); background:var(--wengyan);
    padding:0.9rem 2.2rem; text-decoration:none; transition:background 0.3s;
  }
  .btn-main:hover { background:var(--wengyan-l); }
  .btn-sub {
    font-family:'Jost',sans-serif; font-size:0.68rem;
    letter-spacing:0.2em; text-transform:uppercase;
    color:var(--ink-mid); text-decoration:none;
    border-bottom:1px solid var(--jiliang-3); padding-bottom:2px;
    transition:color 0.3s, border-color 0.3s;
  }
  .btn-sub:hover { color:var(--wengyan); border-color:var(--wengyan); }

  .hero-palette {
    display:flex; gap:1rem; margin-top:3rem; align-items:center;
    opacity:0; animation:fadeUp 1s ease 1.1s forwards;
  }
  .palette-chip { display:flex; flex-direction:column; align-items:center; gap:5px; }
  .palette-dot { width:18px; height:18px; border-radius:50%; }
  .palette-label { font-size:0.52rem; color:var(--ink-dim); letter-spacing:0.08em; text-transform:uppercase; }

  .hero-right {
    position:relative; overflow:hidden;
    display:flex; align-items:center; justify-content:center;
  }
  .hero-art { width:100%; height:100%; min-height:600px; }
  .hero-texture {
    position:absolute; inset:0; z-index:1; pointer-events:none;
    background-image:repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(234,224,200,0.04) 3px, rgba(234,224,200,0.04) 4px);
  }

  /* SECTIONS */
  section { position:relative; z-index:1; }
  .section-label {
    font-family:'Jost', sans-serif;
    font-size:0.6rem; letter-spacing:0.4em; text-transform:uppercase;
    color:var(--wengyan); margin-bottom:1.2rem;
    display:flex; align-items:center; gap:1rem;
  }
  .section-label::after { content:''; display:block; width:24px; height:1px; background:var(--wengyan); }
  .section-title {
    font-family:'Cormorant Garamond', serif;
    font-size:clamp(2rem, 4vw, 3.2rem); font-weight:300;
    color:var(--ink); line-height:1.2; letter-spacing:0.02em;
  }
  .section-title em { color:var(--wengyan); font-style:italic; }

  /* BELIEF */
  .belief { padding:9rem 5rem; background:var(--jiliang); border-top:1px solid var(--jiliang-3); }
  .belief-inner { max-width:1200px; margin:0 auto; }
  .belief-header { max-width:560px; margin-bottom:5rem; }
  .belief-intro {
    font-family:'EB Garamond', serif; font-size:1rem; line-height:1.9;
    color:var(--ink-mid); margin-top:1.5rem; max-width:480px;
  }
  .belief-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--jiliang-3); }
  .belief-card {
    background:var(--jiliang); padding:2.5rem 2rem 2rem;
    transition:background 0.4s; cursor:none; position:relative;
  }
  .belief-card:hover { background:var(--white); }
  .belief-card::after {
    content:''; position:absolute; bottom:0; left:2rem; right:2rem; height:2px;
    background:var(--wengyan); transform:scaleX(0); transform-origin:left; transition:transform 0.4s;
  }
  .belief-card:hover::after { transform:scaleX(1); }
  .belief-herb {
    font-family:'Cormorant Garamond', serif;
    font-size:1rem; font-weight:400; font-style:italic;
    color:var(--wengyan); margin-bottom:0.4rem; letter-spacing:0.05em;
  }
  .belief-herb-cn {
    font-size:0.62rem; letter-spacing:0.25em; color:var(--ink-dim);
    margin-bottom:1.2rem; font-style:normal;
  }
  .belief-emotion {
    font-size:0.56rem; letter-spacing:0.3em; text-transform:uppercase;
    color:var(--chizhang); margin-bottom:0.6rem;
  }
  .belief-name {
    font-family:'Cormorant Garamond', serif;
    font-size:1.3rem; font-weight:400; color:var(--ink);
    margin-bottom:0.8rem; line-height:1.2;
  }
  .belief-desc {
    font-family:'EB Garamond', serif;
    font-size:0.92rem; line-height:1.85; color:var(--ink-mid);
  }
  .belief-card-num {
    position:absolute; top:2rem; right:2rem;
    font-family:'Cormorant Garamond', serif; font-size:2rem; font-weight:300;
    color:var(--jiliang-3); font-style:italic; transition:color 0.4s;
  }
  .belief-card:hover .belief-card-num { color:var(--jiliang-2); }

  /* EMOTIONS */
  .emotions { padding:9rem 5rem; background:var(--jiliang-2); border-top:1px solid var(--jiliang-3); }
  .emotions-inner { max-width:1200px; margin:0 auto; }
  .emotions-header { display:grid; grid-template-columns:1fr 1fr; gap:3rem; margin-bottom:5rem; align-items:end; }
  .emotions-intro { font-family:'EB Garamond', serif; font-size:1rem; line-height:1.9; color:var(--ink-mid); }
  .emotion-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
  .emotion-card {
    background:var(--jiliang); border:1px solid var(--jiliang-3);
    padding:2rem 1.8rem; transition:border-color 0.4s, transform 0.3s; cursor:none;
  }
  .emotion-card:hover { border-color:var(--wengyan); transform:translateY(-4px); }
  .emotion-icon {
    width:44px; height:44px; border-radius:50%;
    display:flex; align-items:center; justify-content:center; margin-bottom:1.5rem;
  }
  .emotion-icon-glyph {
    font-family:'Cormorant Garamond', serif; font-size:1.1rem; font-style:italic; font-weight:400;
  }
  .emotion-tag { font-size:0.56rem; letter-spacing:0.28em; text-transform:uppercase; margin-bottom:0.6rem; }
  .emotion-name {
    font-family:'Cormorant Garamond', serif;
    font-size:1.35rem; font-weight:400; color:var(--ink); margin-bottom:0.8rem;
  }
  .emotion-sub { font-family:'EB Garamond', serif; font-size:0.92rem; line-height:1.85; color:var(--ink-mid); margin-bottom:1.5rem; }
  .emotion-herbs { display:flex; flex-wrap:wrap; gap:0.5rem; }
  .herb-tag { font-size:0.62rem; padding:0.25rem 0.8rem; border-radius:20px; border:1px solid; letter-spacing:0.05em; font-family:'Jost',sans-serif; }

  /* PRODUCT */
  .product { padding:9rem 5rem; background:var(--jiliang); border-top:1px solid var(--jiliang-3); }
  .product-inner { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:6rem; align-items:center; }
  .product-visual {
    aspect-ratio:1; background:var(--jiliang-2); border:1px solid var(--jiliang-3);
    display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden;
  }
  .product-badge {
    position:absolute; top:1.5rem; left:1.5rem;
    font-size:0.56rem; letter-spacing:0.25em; text-transform:uppercase;
    color:var(--wengyan); border:1px solid rgba(74,113,101,0.4); padding:0.35rem 0.9rem;
  }
  .product-meta {
    font-size:0.6rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--ink-dim);
    margin-bottom:1.5rem; display:flex; gap:1rem; align-items:center;
  }
  .product-meta span { color:var(--jiliang-3); }
  .product-name {
    font-family:'Cormorant Garamond', serif;
    font-size:clamp(1.8rem, 3.5vw, 3rem); font-weight:300;
    color:var(--ink); margin-bottom:0.3rem; line-height:1.1;
  }
  .product-name-cn {
    font-size:0.72rem; letter-spacing:0.25em; color:var(--ink-dim);
    margin-bottom:0.5rem;
  }
  .product-name-sub {
    font-family:'EB Garamond', serif;
    font-size:1rem; font-style:italic; color:var(--yingse);
    margin-bottom:2rem; letter-spacing:0.06em;
  }
  .product-desc { font-family:'EB Garamond', serif; font-size:0.95rem; line-height:1.95; color:var(--ink-mid); margin-bottom:2.5rem; }
  .product-props {
    display:grid; grid-template-columns:1fr 1fr; gap:1.2rem 2rem;
    border-top:1px solid var(--jiliang-3); padding-top:2rem; margin-bottom:2.5rem;
  }
  .prop-label { font-size:0.56rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--wengyan); margin-bottom:0.3rem; }
  .prop-val { font-family:'EB Garamond', serif; font-size:0.95rem; color:var(--ink); }
  .product-price {
    font-family:'Cormorant Garamond', serif; font-size:2.2rem; color:var(--ink); font-weight:300; margin-bottom:2rem;
  }
  .product-price sup { font-size:1rem; vertical-align:super; }
  .product-actions { display:flex; gap:1rem; align-items:center; }

  /* RITUAL */
  .ritual { padding:9rem 5rem; background:var(--wengyan); border-top:1px solid var(--jiliang-3); }
  .ritual-inner { max-width:900px; margin:0 auto; text-align:center; }
  .ritual .section-label { justify-content:center; color:rgba(242,235,216,0.65); }
  .ritual .section-label::after { background:rgba(242,235,216,0.35); }
  .ritual .section-title { color:var(--jiliang); margin-bottom:5rem; }
  .ritual .section-title em { color:var(--yingse-l); }
  .ritual-steps { display:grid; grid-template-columns:repeat(3,1fr); gap:3rem; }
  .ritual-step { text-align:center; }
  .step-circle {
    width:60px; height:60px; border-radius:50%;
    border:1px solid rgba(242,235,216,0.3);
    display:flex; align-items:center; justify-content:center;
    margin:0 auto 1.8rem;
    font-family:'Cormorant Garamond', serif; font-size:1.4rem;
    color:var(--yingse-l); font-style:italic;
    transition:background 0.4s, border-color 0.4s;
  }
  .ritual-step:hover .step-circle { background:rgba(242,235,216,0.08); border-color:rgba(242,235,216,0.6); }
  .step-name { font-family:'Cormorant Garamond', serif; font-size:1.2rem; font-weight:400; color:var(--jiliang); margin-bottom:1rem; }
  .step-desc { font-family:'EB Garamond', serif; font-size:0.95rem; line-height:1.9; color:rgba(242,235,216,0.65); }

  /* TESTIMONIAL */
  .testimony { padding:7rem 5rem; background:var(--jiliang-2); border-top:1px solid var(--jiliang-3); text-align:center; }
  .testimony-stars { color:var(--yingse); letter-spacing:0.3em; margin-bottom:2rem; font-size:0.85rem; }
  .testimony-quote {
    font-family:'Cormorant Garamond', serif;
    font-size:clamp(1.2rem, 2.5vw, 1.9rem); font-weight:300; font-style:italic;
    color:var(--ink); max-width:680px; margin:0 auto 2rem; line-height:1.7;
  }
  .testimony-author { font-size:0.62rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--ink-dim); }

  /* NEWSLETTER */
  .newsletter { padding:8rem 5rem; background:var(--jiliang); border-top:1px solid var(--jiliang-3); text-align:center; }
  .newsletter-kicker { font-size:0.6rem; letter-spacing:0.4em; text-transform:uppercase; color:var(--wengyan); margin-bottom:1.5rem; }
  .newsletter-title { font-family:'Cormorant Garamond', serif; font-size:clamp(1.8rem, 3.5vw, 2.8rem); font-weight:300; color:var(--ink); margin-bottom:1rem; }
  .newsletter-title em { font-style:italic; color:var(--wengyan); }
  .newsletter-sub { font-family:'EB Garamond', serif; font-size:1rem; color:var(--ink-dim); margin-bottom:2.8rem; line-height:1.8; }
  .newsletter-form { display:flex; max-width:420px; margin:0 auto; border:1px solid var(--jiliang-3); background:var(--white); transition:border-color 0.3s; }
  .newsletter-form:focus-within { border-color:var(--wengyan); }
  .newsletter-form input { flex:1; background:transparent; border:none; outline:none; padding:0.9rem 1.4rem; font-family:'EB Garamond',serif; font-size:0.95rem; color:var(--ink); }
  .newsletter-form input::placeholder { color:var(--ink-dim); }
  .newsletter-form button { background:var(--wengyan); border:none; padding:0 1.4rem; font-family:'Jost',sans-serif; font-size:0.62rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--white); cursor:none; white-space:nowrap; transition:background 0.3s; }
  .newsletter-form button:hover { background:var(--wengyan-l); }

  /* FOOTER */
  footer { background:var(--ink); padding:4rem 5rem; border-top:1px solid rgba(255,255,255,0.08); }
  .footer-inner { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1.8fr 1fr 1fr 1fr; gap:4rem; }
  .footer-brand { font-family:'Cormorant Garamond',serif; font-size:1.4rem; font-weight:300; color:var(--jiliang); letter-spacing:0.2em; margin-bottom:1rem; }
  .footer-tagline { font-family:'EB Garamond',serif; font-size:0.88rem; line-height:1.9; color:rgba(242,235,216,0.45); }
  .footer-h { font-size:0.58rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--yingse); margin-bottom:1.5rem; }
  .footer-links { list-style:none; }
  .footer-links li { margin-bottom:0.75rem; }
  .footer-links a { font-family:'EB Garamond',serif; font-size:0.92rem; color:rgba(242,235,216,0.45); text-decoration:none; transition:color 0.3s; }
  .footer-links a:hover { color:var(--jiliang); }
  .footer-bottom { max-width:1200px; margin:3rem auto 0; padding-top:2rem; border-top:1px solid rgba(255,255,255,0.07); display:flex; justify-content:space-between; font-size:0.6rem; letter-spacing:0.1em; color:rgba(242,235,216,0.25); }

  @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
  .reveal { opacity:0; transform:translateY(24px); transition:opacity 0.9s ease, transform 0.9s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }
  .reveal-delay-1 { transition-delay:0.12s; }
  .reveal-delay-2 { transition-delay:0.24s; }
  .reveal-delay-3 { transition-delay:0.36s; }

  @media(max-width:900px) {
    .hero { grid-template-columns:1fr; }
    nav { padding:1.4rem 2rem; }
    .nav-links { display:none; }
    .belief { padding:5rem 2rem; }
    .belief-grid { grid-template-columns:1fr 1fr; }
    .emotions,.product,.ritual { padding:5rem 2rem; }
    .emotions-header,.product-inner { grid-template-columns:1fr; }
    .emotion-grid { grid-template-columns:1fr; }
    .ritual-steps { grid-template-columns:1fr; gap:2rem; }
    .footer-inner { grid-template-columns:1fr 1fr; }
  }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">
    YÀOCǍO
    <span class="nav-logo-sub">· Ancient Herb Intention</span>
  </a>
  <ul class="nav-links">
    <li><a href="#belief">Belief System</a></li>
    <li><a href="#emotions">Emotional Solutions</a></li>
    <li><a href="#product">Shop</a></li>
    <li><a href="#ritual">The Ritual</a></li>
    <li><a href="find-my-herb.html" class="nav-find-link">Find My Herb</a></li>
  </ul>
  <a href="find-my-herb.html" class="nav-cta">Find Your Herb</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">Ancient Herb · Belief · Emotional Healing</p>

    <h1 class="hero-title">
      The Herb<br>
      <em>Remembers</em><br>
      You
    </h1>
    <p class="hero-subtitle">藥草 · A Letter from the Earth</p>

    <p class="hero-desc">
      Twelve ancient herbs. Twelve emotional intentions.<br>
      Each bracelet is a belief system you wear on your wrist —
      not an accessory, but a solemn promise to yourself.
    </p>

    <div class="hero-actions">
      <a href="#belief" class="btn-main">Explore the Belief System</a>
      <a href="find-my-herb.html" class="btn-sub">Find My Herb</a>
    </div>

    <div class="entry-strip">
      <span class="entry-strip-label">Herb Quiz</span>
      <a href="find-my-herb.html">Enter Find My Herb</a>
